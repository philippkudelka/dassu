{
  "rules": {
    ".read": false,
    ".write": false,

    "bookings": {
      ".read": "auth != null",
      ".indexOn": ["date"],
      "$bookingId": {
        ".write": "auth != null && (root.child('staffUsers').child(auth.uid).exists() || (!data.exists() && newData.child('uid').val() === auth.uid) || (data.exists() && data.child('uid').val() === auth.uid))",
        "aircraft": { ".validate": "newData.isString() && newData.val().length <= 120" },
        "date":     { ".validate": "newData.isString() && newData.val().length <= 20" },
        "status":   { ".validate": "newData.isString() && newData.val().length <= 20 && (root.child('staffUsers').child(auth.uid).exists() || newData.val() === 'pending' || (data.exists() && newData.val() === data.val()))" }
      }
    },

    "bookingContacts": {
      ".read": "auth != null && root.child('staffUsers').child(auth.uid).exists()",
      "$bookingId": {
        ".read": "auth != null && (root.child('staffUsers').child(auth.uid).exists() || data.child('uid').val() === auth.uid)",
        ".write": "auth != null && (root.child('staffUsers').child(auth.uid).exists() || (!data.exists() && newData.child('uid').val() === auth.uid) || (data.exists() && data.child('uid').val() === auth.uid))",
        "name":    { ".validate": "newData.isString() && newData.val().length <= 200" },
        "email":   { ".validate": "newData.isString() && newData.val().length <= 200" },
        "phone":   { ".validate": "newData.isString() && newData.val().length <= 80" },
        "comment": { ".validate": "newData.isString() && newData.val().length <= 2000" }
      }
    },

    "settings": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('staffUsers').child(auth.uid).child('role').val() === 'admin' || root.child('staffUsers').child(auth.uid).child('role').val() === 'team')"
    },

    "staffUsers": {
      ".read": "auth != null && root.child('staffUsers').child(auth.uid).exists()",
      ".indexOn": ["email"],
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('staffUsers').child(auth.uid).child('role').val() === 'admin' || auth.uid === $uid)",
        "role": {
          ".validate": "root.child('staffUsers').child(auth.uid).child('role').val() === 'admin' || newData.val() === root.child('invitations').child(auth.token.email.toLowerCase().replace('.', ',').replace('@', '__at__').replace('#', '__hash__').replace('$', '__dollar__').replace('[', '__lb__').replace(']', '__rb__')).child('role').val()"
        },
        "permissions": {
          ".validate": "root.child('staffUsers').child(auth.uid).child('role').val() === 'admin'"
        },
        "name":      { ".validate": "newData.isString() && newData.val().length <= 200" },
        "email":     { ".validate": "newData.isString() && newData.val().length <= 200" },
        "phone":     { ".validate": "newData.isString() && newData.val().length <= 80" },
        "birthdate": { ".validate": "newData.isString() && newData.val().length <= 20" },
        "photoURL":  { ".validate": "newData.isString() && newData.val().length <= 2000000" },
        "createdAt": { ".validate": "newData.isNumber()" }
      }
    },

    "customers": {
      ".indexOn": ["customerType"],
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('staffUsers').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid === $uid || root.child('staffUsers').child(auth.uid).child('role').val() === 'admin')",
        "customerType": {
          ".validate": "root.child('staffUsers').child(auth.uid).exists() || newData.val() === 'charter' || newData.val() === 'student'"
        },
        "assignedTraining": {
          ".validate": "root.child('staffUsers').child(auth.uid).child('role').val() === 'admin' && newData.isString() && newData.val().length <= 64"
        },
        "name":      { ".validate": "newData.isString() && newData.val().length <= 200" },
        "email":     { ".validate": "newData.isString() && newData.val().length <= 200" },
        "phone":     { ".validate": "newData.isString() && newData.val().length <= 80" },
        "birthdate": { ".validate": "newData.isString() && newData.val().length <= 20" },
        "street":    { ".validate": "newData.isString() && newData.val().length <= 200" },
        "zip":       { ".validate": "newData.isString() && newData.val().length <= 20" },
        "city":      { ".validate": "newData.isString() && newData.val().length <= 100" },
        "country":   { ".validate": "newData.isString() && newData.val().length <= 100" },
        "photoURL":  { ".validate": "newData.isString() && newData.val().length <= 2000000" },
        "walkIn":    { ".validate": "newData.isBoolean()" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "createdBy": { ".validate": "newData.isString() && newData.val().length <= 200" }
      },
      ".read": "auth != null && root.child('staffUsers').child(auth.uid).exists()"
    },

    "invitations": {
      ".read": "auth != null && root.child('staffUsers').child(auth.uid).child('role').val() === 'admin'",
      "$key": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('staffUsers').child(auth.uid).child('role').val() === 'admin' || !newData.exists())"
      }
    },

    "theoryLessons": {
      ".read": "auth != null && root.child('staffUsers').child(auth.uid).exists()",
      ".write": "auth != null && root.child('staffUsers').child(auth.uid).exists()"
    },

    "messages": {
      ".read": "auth != null && root.child('staffUsers').child(auth.uid).exists()",
      ".indexOn": ["createdAt"],
      "$mid": {
        ".write": "auth != null && ((!data.exists() && newData.exists() && (root.child('staffUsers').child(auth.uid).child('role').val() === 'admin' || root.child('staffUsers').child(auth.uid).child('role').val() === 'team')) || (!newData.exists() && root.child('staffUsers').child(auth.uid).child('role').val() === 'admin'))",
        "title":    { ".validate": "newData.isString() && newData.val().length <= 200" },
        "body":     { ".validate": "newData.isString() && newData.val().length <= 5000" },
        "category": { ".validate": "newData.isString() && newData.val().length <= 32" },
        "readBy": {
          "$r": { ".write": "auth != null && $r === auth.uid && root.child('staffUsers').child(auth.uid).exists()" }
        }
      }
    },

    "internalMessages": {
      ".read": "auth != null && (root.child('staffUsers').child(auth.uid).child('role').val() === 'admin' || root.child('staffUsers').child(auth.uid).child('role').val() === 'team')",
      "$auid": {
        ".read": "auth != null && auth.uid === $auid",
        ".indexOn": ["createdAt"],
        "$mid": {
          ".write": "auth != null && ((!data.exists() && newData.exists() && auth.uid === $auid && root.child('staffUsers').child(auth.uid).exists()) || (!newData.exists() && root.child('staffUsers').child(auth.uid).child('role').val() === 'admin'))",
          "title":         { ".validate": "newData.isString() && newData.val().length <= 200" },
          "body":          { ".validate": "newData.isString() && newData.val().length <= 5000" },
          "category":      { ".validate": "newData.isString() && newData.val().length <= 32" },
          "createdByRole": { ".validate": "newData.isString() && newData.val().length <= 32" },
          "readBy": {
            "$r": { ".write": "auth != null && $r === auth.uid && (auth.uid === $auid || root.child('staffUsers').child(auth.uid).child('role').val() === 'admin' || root.child('staffUsers').child(auth.uid).child('role').val() === 'team')" }
          }
        }
      }
    },

    "pushTokens": {
      ".read": false,
      "$tokenKey": {
        ".write": "auth != null && ((newData.exists() && newData.child('userId').val() === auth.uid && (!data.exists() || data.child('userId').val() === auth.uid)) || (!newData.exists() && data.child('userId').val() === auth.uid))",
        "userId":    { ".validate": "newData.isString() && newData.val().length <= 200" },
        "token":     { ".validate": "newData.isString() && newData.val().length <= 500" },
        "user":      { ".validate": "newData.isString() && newData.val().length <= 200" },
        "ua":        { ".validate": "newData.isString() && newData.val().length <= 200" },
        "updatedAt": { ".validate": "newData.isString() && newData.val().length <= 40" }
      }
    },

    "gastfluglehrer": {
      ".read": "auth != null && root.child('staffUsers').child(auth.uid).exists()",
      ".write": "auth != null && root.child('staffUsers').child(auth.uid).exists()"
    },

    "dailyNotes": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('staffUsers').child(auth.uid).exists()"
    },

    "activityLog": {
      ".read": "auth != null && root.child('staffUsers').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('staffUsers').child(auth.uid).exists()",
      ".indexOn": ["timestamp"]
    },

    "audit": {
      "$bookingId": {
        ".read": "auth != null && root.child('staffUsers').child(auth.uid).exists()",
        ".write": "auth != null && root.child('staffUsers').child(auth.uid).exists()"
      }
    },

    "timeEntries": {
      ".read": "auth != null && root.child('staffUsers').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('staffUsers').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('staffUsers').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "timeSettings": {
      ".read": "auth != null && root.child('staffUsers').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('staffUsers').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('staffUsers').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "users": {
      ".read": false,
      ".write": false,
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "icalToken": { ".validate": "newData.isString() && newData.val().length >= 24 && newData.val().length <= 128" },
        "icalName":  { ".validate": "newData.isString() && newData.val().length <= 200" },
        "icalCreatedAt": { ".validate": "newData.isNumber()" }
      }
    },

    "training": {
      ".read": false,
      ".write": false
    },

    "errorLog": {
      ".read": "auth != null && root.child('staffUsers').child(auth.uid).child('role').val() === 'admin'",
      "$id": {
        ".write": "auth != null && !data.exists()",
        ".validate": "newData.hasChildren(['ts', 'message'])",
        "message":   { ".validate": "newData.isString() && newData.val().length <= 500" },
        "stack":     { ".validate": "newData.isString() && newData.val().length <= 2000" },
        "source":    { ".validate": "newData.isString() && newData.val().length <= 300" },
        "url":       { ".validate": "newData.isString() && newData.val().length <= 300" },
        "userAgent": { ".validate": "newData.isString() && newData.val().length <= 400" }
      }
    },

    "_rateLimits": {
      ".read": false,
      ".write": false
    }
  }
}
